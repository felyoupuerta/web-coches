<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="Servicio profesional de importación de coches premium desde Alemania a España. Garantía, rapidez y gestión integral.">
    <title><%= title || 'Importación de Coches de Alemania a España' %></title>
    <!-- Fuentes premium -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Outfit:wght@400;600;700;800&display=swap" rel="stylesheet">
    <!-- Iconos Lucide (CDN ligero) -->
    <script src="https://unpkg.com/lucide@latest"></script>
    <!-- Estilos personalizados -->
    <link rel="stylesheet" href="/css/styles.css">
</head>
<body>
    <header class="app-header">
        <div class="container navbar">
            <a href="/" class="logo">
                <span class="logo-accent">DEUTSCH</span><span class="logo-main">IMPORT</span>
            </a>
            
            <nav class="nav-menu">
                <a href="/" class="nav-link"><i data-lucide="car"></i> Catálogo</a>
                <a href="/importar" class="nav-link"><i data-lucide="file-text"></i> Solicitar Importación</a>
                <% if (adminUser) { %>
                    <a href="/admin/dashboard" class="nav-link nav-admin"><i data-lucide="layout-dashboard"></i> Panel Admin</a>
                    <a href="/admin/cars" class="nav-link nav-admin"><i data-lucide="plus-circle"></i> Catálogo Admin</a>
                    <a href="/admin/usuarios" class="nav-link nav-admin"><i data-lucide="users"></i> Usuarios</a>
                    <a href="/admin/logout" class="nav-link logout-btn"><i data-lucide="log-out"></i> Salir (<%= adminUser %>)</a>
                <% } else { %>
                    <a href="/admin/login" class="nav-link login-link"><i data-lucide="lock"></i> Acceso Admin</a>
                <% } %>
            </nav>
            <button class="menu-toggle" aria-label="Abrir menú">
                <i data-lucide="menu"></i>
            </button>
        </div>
    </header>
    <main class="main-content container">
