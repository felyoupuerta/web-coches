<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta name="description" content="Luxe Imports: importación premium de vehículos de Alemania a España. Selección verificada, transporte asegurado y gestión de matriculación llave en mano.">
    <meta name="theme-color" content="#0b0f19">
    <meta property="og:type" content="website">
    <meta property="og:site_name" content="Luxe Imports">
    <meta property="og:title" content="<%= title || 'Luxe Imports - Importación Premium de Vehículos' %>">
    <meta property="og:description" content="Importación premium de vehículos de Alemania a España, con gestión integral y garantía de confianza.">
    <title><%= title || 'Luxe Imports - Importación Premium de Vehículos' %></title>
    <link rel="icon" href="data:image/svg+xml,<svg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 100 100'><rect width='100' height='100' rx='20' fill='%230b0f19'/><text x='50' y='68' font-family='Georgia,serif' font-size='58' font-weight='700' fill='%23f59e0b' text-anchor='middle'>L</text></svg>">
    <!-- Fuentes premium -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&family=Outfit:wght@400;600;700;800&display=swap" rel="stylesheet">
    <!-- Iconos Lucide (CDN ligero) -->
    <script src="https://unpkg.com/lucide@latest" defer></script>
    <!-- Estilos personalizados -->
    <link rel="stylesheet" href="/css/styles.css">
</head>
<body>
    <a href="#main-content" class="skip-link">Saltar al contenido principal</a>
    <header class="app-header">
        <div class="container navbar">
            <a href="/" class="logo">
                <span class="logo-accent">LUXE</span><span class="logo-main">IMPORTS</span>
            </a>

            <nav class="nav-menu">
                <a href="/" class="nav-link"><i data-lucide="home"></i> Inicio</a>
                <a href="/#wizard-busqueda" class="nav-link"><i data-lucide="search"></i> Búsqueda a la Carta</a>
                <a href="/#calculadora" class="nav-link"><i data-lucide="calculator"></i> Calculadora</a>
                <a href="/#proceso" class="nav-link"><i data-lucide="list-checks"></i> Cómo Funciona</a>
                <a href="/catalogo" class="nav-link"><i data-lucide="car"></i> Vehículos Disponibles</a>
                <a href="/#faq" class="nav-link"><i data-lucide="help-circle"></i> FAQ</a>
                <% if (adminUser) { %>
                    <a href="/admin/dashboard" class="nav-link nav-admin"><i data-lucide="layout-dashboard"></i> Panel Admin</a>
                    <a href="/admin/contabilidad" class="nav-link nav-admin"><i data-lucide="calculator"></i> Contabilidad</a>
                    <a href="/admin/cars" class="nav-link nav-admin"><i data-lucide="plus-circle"></i> Catálogo Admin</a>
                    <a href="/admin/busquedas" class="nav-link nav-admin"><i data-lucide="inbox"></i> Búsquedas a la Carta</a>
                    <a href="/admin/usuarios" class="nav-link nav-admin"><i data-lucide="users"></i> Usuarios</a>
                    <a href="/admin/logout" class="nav-link logout-btn"><i data-lucide="log-out"></i> Salir (<%= adminUser %>)</a>
                <% } else { %>
                    <a href="/admin/login" class="nav-link login-link"><i data-lucide="lock"></i> Acceso Admin</a>
                <% } %>
            </nav>
            <button class="menu-toggle" aria-label="Abrir menú" aria-expanded="false">
                <i data-lucide="menu"></i>
            </button>
        </div>
    </header>
    <main id="main-content" class="main-content container">
