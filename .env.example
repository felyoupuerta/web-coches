# Copia este archivo a .env y ajusta los valores reales antes de desplegar.
# NUNCA subas el archivo .env real a git (ya está en .gitignore).

PORT=3000
HOST=0.0.0.0
NODE_ENV=production
LOG_LEVEL=error

# Base de datos MariaDB (LXC aislado en red interna, sin salida a Internet)
DB_HOST=10.0.30.50
DB_PORT=3306
DB_USER=luxe_user
DB_PASS=CambiaEstePasswordAntesDeDesplegar
DB_NAME=db_luxe_imports

# Genera un valor aleatorio real con: openssl rand -hex 32
# La aplicación se niega a arrancar en producción si esto no está definido.
SESSION_SECRET=
